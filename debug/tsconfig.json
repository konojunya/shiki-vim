{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "shiki-vim": ["../src/index.ts"],
      "shiki-vim/styles.css": ["../src/styles.css"]
    }
  },
  "include": ["src"]
}
